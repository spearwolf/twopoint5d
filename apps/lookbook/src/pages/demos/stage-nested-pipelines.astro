---
import Layout from '~layouts/VanillaDemo.astro';
import {description, showSource, title} from './_stage-nested-pipelines.json';
---

<Layout title={title} showSource={showSource}>
  <canvas id="twopoint5d" resize-to="window"></canvas>

  <p slot="demo-description">{description}</p>
</Layout>

<script>
  import {on} from '@spearwolf/eventize';
  import {
    Display,
    OnStageUpdateFrame,
    ParallaxProjection,
    RootRenderPipeline,
    Stage2D,
    StageRenderer,
    TextureFactory,
    type StageUpdateFrameProps,
  } from '@spearwolf/twopoint5d';
  import {bloom} from 'three/examples/jsm/tsl/display/BloomNode.js';
  import {Color, RenderPipeline, Sprite, SpriteMaterial} from 'three/webgpu';
  import assetsUrl from '~demos/utils/assetsUrl';

  const canvas = document.getElementById('twopoint5d')!;
  const display = new Display(canvas);

  const textureFactory = new TextureFactory(display.renderer, ['nearest', 'srgb', 'flipy']);
  const ballTexture = textureFactory.load(assetsUrl('skinball-256.png'));
  const logoTexture = textureFactory.load(assetsUrl('spearwolf-ahsh-1504x359.png'));

  // ---------------------------------------------------------------
  // Outer renderer composes the two layers via its OWN pipeline.
  // RenderPipeline must own the final draw to the canvas — see §6.3
  // in `Backlog-StageRenderer.md`. Mixing pipeline.render() with
  // raw renderer.render(scene, camera) on the canvas inside one
  // frame is not supported.
  // ---------------------------------------------------------------
  const root = new StageRenderer(display).setClearColor(new Color('#000'), 1);

  // ---------------------------------------------------------------
  // World layer (with its OWN bloom pipeline, pre-rendered into a
  // texture by the root pipeline)
  // ---------------------------------------------------------------
  const worldStage = new Stage2D(new ParallaxProjection('xy|bottom-left', {width: 800, height: 600, fit: 'contain'}));
  worldStage.name = 'world';

  const worldRenderer = new StageRenderer(root).setClearColor(new Color('#0a0a1f'), 1).add(worldStage);
  worldRenderer.name = 'world-renderer';
  worldRenderer.pipeline = new RenderPipeline(display.renderer);
  worldRenderer.buildOutputNode = ([scenePass]) => scenePass.add(bloom(scenePass, 1.5, 0.5, 0.0));

  const palette = ['#ffd166', '#ef476f', '#06d6a0', '#118ab2', '#ffe0b3'];
  const worldSprites: Sprite[] = [];
  for (let i = 0; i < 24; i++) {
    const sprite = new Sprite(new SpriteMaterial({map: ballTexture, color: new Color(palette[i % palette.length])}));
    sprite.scale.set(50, 50, 1);
    worldStage.scene.add(sprite);
    worldSprites.push(sprite);
  }

  const phases = worldSprites.map((_, i) => i * ((Math.PI * 2) / worldSprites.length));
  on(worldStage, OnStageUpdateFrame, ({now}: StageUpdateFrameProps) => {
    for (let i = 0; i < worldSprites.length; i++) {
      const a = phases[i] + now * 0.5;
      worldSprites[i].position.set(Math.cos(a) * 220, Math.sin(a * 1.3) * 160, 0);
    }
  });

  // ---------------------------------------------------------------
  // UI layer (plain pass, composed on top of the world)
  // ---------------------------------------------------------------
  const uiStage = new Stage2D(new ParallaxProjection('xy|bottom-left', {width: 800, height: 600, fit: 'contain'}));
  uiStage.name = 'ui';
  const logoSprite = new Sprite(new SpriteMaterial({map: logoTexture, transparent: true}));
  logoSprite.scale.set(420, 100, 1);
  logoSprite.position.set(-150, 220, 0);
  uiStage.scene.add(logoSprite);

  root.add(uiStage);

  // ---------------------------------------------------------------
  // Root pipeline: a `RootRenderPipeline` composes every child pass
  // additively, so no `buildOutputNode` boilerplate is needed.
  // ---------------------------------------------------------------
  root.pipeline = new RootRenderPipeline(display.renderer);

  display.start();

  (window as any).display = display;
  (window as any).root = root;
  (window as any).worldRenderer = worldRenderer;
</script>
